datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  roles     UserRole[]
  createdAt DateTime   @default(now())
}

model Role {
  id    String     @id @default(cuid())
  name  RoleType   @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

enum RoleType {
  STUDENT
  ADMIN
  DEPARTMENT_HEAD
  REGISTRAR
  LIBRARY
  FINANCE
  DORMITORY
  CAFETERIA
  ICT
  SECURITY
}