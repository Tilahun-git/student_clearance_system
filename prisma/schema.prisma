generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  createdAt          DateTime       @default(now())
  name               String
  isActive           Boolean        @default(true)
  mustChangePassword Boolean        @default(false)
  notifications      Notification[]
  staffProfile       Staff?
  studentProfile     Student?
  proctorProfile     Proctor?
  roles              UserRole[]
}

model Role {
  id        String              @id @default(uuid())
  name      RoleType            @unique
  approvals ClearanceApproval[]
  users     UserRole[]
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
}

model Proctor {
  id                String                @id @default(uuid())
  userId            String                @unique
  firstName         String
  lastName          String
  middleName        String?
  email             String                @unique
  blockNumber       Int?                  @unique
  isSuperProctor    Boolean               @default(false)
  students          Student[]
  user              User?                  @relation(fields: [userId], references: [id])

}

model Student {
  id                String                 @id @default(uuid())
  userId            String?                @unique
  advisorId         String?
  departmentId      String
  proctorId         String?        
  program           String
  year              Int
  studentId         String                 @unique
  firstName         String
  lastName          String
  middleName        String?
  schoolId          String?
  section           String                 @default("A")
  certificates      ClearanceCertificate[]
  clearanceRequests ClearanceRequest[]
  libraryBorrows    LibraryBorrow[]
  advisor           Staff?                 @relation("AdvisorStudents", fields: [advisorId], references: [id])
  department        Department             @relation(fields: [departmentId], references: [id])
  school            School?                @relation(fields: [schoolId], references: [id])
  user              User?                  @relation(fields: [userId], references: [id])
  proctor           Proctor?               @relation(fields: [proctorId], references: [id])
}

model Staff {
  id                  String                 @id @default(uuid())
  userId              String                 @unique
  schoolId            String?
  departmentId        String?
  approvals           ClearanceApproval[]
  managedOffices      ClearanceStaffOffice[] @relation("OfficeManager")
  headOfDepartment    Department?            @relation("DepartmentHead")
  libraryBorrowsAdded LibraryBorrow[]
  deanOfSchool        School?                @relation("SchoolDean")
  department          Department?            @relation(fields: [departmentId], references: [id])
  school              School?                @relation(fields: [schoolId], references: [id])
  user                User                   @relation(fields: [userId], references: [id])
  advisees            Student[]              @relation("AdvisorStudents")
}

model ClearanceStaffOffice {
  id          String              @id @default(uuid())
  office_name String
  managerId   String?
  code        String              @unique
  approvals   ClearanceApproval[]
  manager     Staff?              @relation("OfficeManager", fields: [managerId], references: [id])
}

model School {
  id                String             @id @default(uuid())
  name              String
  school_deanId     String?            @unique
  clearanceRequests ClearanceRequest[]
  departments       Department[]
  school_dean       Staff?             @relation("SchoolDean", fields: [school_deanId], references: [id])
  staff             Staff[]
  students          Student[]
}

model Department {
  id                String             @id @default(uuid())
  name              String
  schoolId          String
  headId            String?            @unique
  clearanceRequests ClearanceRequest[]
  head              Staff?             @relation("DepartmentHead", fields: [headId], references: [id])
  school            School             @relation(fields: [schoolId], references: [id])
  staff             Staff[]
  students          Student[]
}

model ClearanceRequest {
  id                String                @id @default(uuid())
  studentId         String
  createdAt         DateTime              @default(now())
  academicYear      String?
  reason            String
  semester          String?
  status            ClearanceStatus       @default(PENDING)
  departmentId      String?
  schoolId          String?
  rejectedByRole    String?
  resubmissionCount Int                   @default(0)
  approvals         ClearanceApproval[]
  certificate       ClearanceCertificate?
  department        Department?           @relation(fields: [departmentId], references: [id])
  school            School?               @relation(fields: [schoolId], references: [id])
  student           Student               @relation(fields: [studentId], references: [id])
}

model ClearanceApproval {
  id                 String                @id @default(uuid())
  clearanceRequestId String
  roleId             String
  staffId            String?
  status             ApprovalStatus        @default(PENDING)
  comment            String?
  approvedAt         DateTime?
  officeId           String?
  clearanceRequest   ClearanceRequest      @relation(fields: [clearanceRequestId], references: [id])
  office             ClearanceStaffOffice? @relation(fields: [officeId], references: [id])
  role               Role                  @relation(fields: [roleId], references: [id])
  staff              Staff?                @relation(fields: [staffId], references: [id])

  @@unique([clearanceRequestId, roleId])
}

model ClearanceCertificate {
  id        String           @id @default(uuid())
  studentId String
  requestId String           @unique
  fileUrl   String
  fileName  String
  issuedAt  DateTime         @default(now())
  publicId  String?
  request   ClearanceRequest @relation(fields: [requestId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])
}

model LibraryBorrow {
  id        String   @id @default(uuid())
  studentId String
  addedBy   String
  returned  Boolean  @default(false)
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [addedBy], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  referenceId String?
  forRole     String?
  user        User     @relation(fields: [userId], references: [id])
}

enum ClearanceStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  WAITING
  APPROVED
  REJECTED
}

enum RoleType {
  STUDENT
  ADVISOR
  DEPARTMENT_HEAD
  SCHOOL_DEAN
  FINANCE
  LIBRARY
  REGISTRAR
  ADMIN
  CAFETERIA
  DORMITORY
  STUDENT_DEAN
  CAMPUS_POLICE
  SUPER_PROCTOR
}
