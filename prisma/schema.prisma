generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  STUDENT
  ADVISOR
  DEPARTMENT_HEAD
  FINANCE
  LIBRARY
  REGISTRAR
  ADMIN
  SCHOOL_DEAN
}

enum ClearanceStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  roles UserRole[]

  studentProfile Student?
  staffProfile   Staff?
}

model Role {
  id   String   @id @default(uuid())
  name RoleType @unique

  users     UserRole[]
  approvals ClearanceApproval[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Student {
  id     String  @id @default(uuid())
  userId String? @unique

  studentId String @unique

  program String
  year    Int

  firstName  String
  middleName String?
  lastName   String

  facultyId    String?
  schoolId     String?
  departmentId String
  advisorId    String?

  user       User?      @relation(fields: [userId], references: [id])
  faculty    Faculty?    @relation(fields: [facultyId], references: [id])
  school     School?     @relation(fields: [schoolId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  advisor    Staff?     @relation("AdvisorStudents", fields: [advisorId], references: [id])

  clearanceRequests ClearanceRequest[]
  certificates      ClearanceCertificate[]
}

model Staff {
  id     String @id @default(uuid())
  userId String @unique

  facultyId    String?
  schoolId     String?
  departmentId String?

  user       User        @relation(fields: [userId], references: [id])
  faculty    Faculty?    @relation(fields: [facultyId], references: [id])
  school     School?     @relation(fields: [schoolId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  advisees Student[] @relation("AdvisorStudents")

  approvals ClearanceApproval[]
}

model Faculty {
  id   String @id @default(uuid())
  name String

  schools           School[]
  staff             Staff[]
  clearanceRequests ClearanceRequest[]
  students          Student[]
}

model School {
  id        String @id @default(uuid())
  name      String
  facultyId String

  faculty Faculty @relation(fields: [facultyId], references: [id])

  departments       Department[]
  staff             Staff[]
  clearanceRequests ClearanceRequest[]
  students          Student[]
}

model Department {
  id       String @id @default(uuid())
  name     String
  schoolId String

  school School @relation(fields: [schoolId], references: [id])

  students          Student[]
  staff             Staff[]
  clearanceRequests ClearanceRequest[]
}

model ClearanceRequest {
  id        String   @id @default(uuid())
  studentId String
  createdAt DateTime @default(now())

  reason       String
  academicYear String?
  semester     String?

  facultyId    String?
  schoolId     String?
  departmentId String?

  currentStep RoleType @default(ADVISOR)

  status ClearanceStatus @default(PENDING)

  student    Student     @relation(fields: [studentId], references: [id])
  faculty    Faculty?    @relation(fields: [facultyId], references: [id])
  school     School?     @relation(fields: [schoolId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  approvals   ClearanceApproval[]
  certificate ClearanceCertificate?
}

model ClearanceApproval {
  id                 String  @id @default(uuid())
  clearanceRequestId String
  roleId             String
  staffId            String?

  status     ApprovalStatus @default(PENDING)
  comment    String?
  approvedAt DateTime?

  clearanceRequest ClearanceRequest @relation(fields: [clearanceRequestId], references: [id])
  role             Role             @relation(fields: [roleId], references: [id])
  staff            Staff?           @relation(fields: [staffId], references: [id])
}

model ClearanceCertificate {
  id        String @id @default(uuid())
  studentId String
  requestId String @unique

  fileUrl  String
  fileName String

  issuedAt DateTime @default(now())

  student Student          @relation(fields: [studentId], references: [id])
  request ClearanceRequest @relation(fields: [requestId], references: [id])
}
